{
  "name": "ares",
  "version": "0.25.0",
  "private": true,
  "type": "module",
  "bin": {
    "ares": "packages/cli/dist/entry.js"
  },
  "packageManager": "pnpm@10.33.0",
  "description": "Ares: a streaming, multi-provider coding + autonomous agent (Anthropic, OpenAI, Ollama Cloud, OpenRouter, DeepSeek) with a Tauri desktop and terminal â€” continuous verifier, multi-session daemon, persistent agent mind, and real desktop control.",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "lint": "pnpm check",
    "test": "pnpm build && node --test tests/*.test.mjs",
    "ares": "node packages/cli/dist/entry.js",
    "install:cli": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "uninstall:cli": "powershell -ExecutionPolicy Bypass -File scripts/uninstall.ps1",
    "link:cli": "pnpm build && pnpm link --global",
    "verify": "pnpm lint && pnpm test",
    "clean": "node scripts/clean.mjs",
    "desktop:installer": "pnpm build && pnpm --filter ares-tauri build",
    "voice:tts": "powershell -ExecutionPolicy Bypass -File scripts/voice-tts.ps1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "esbuild": "0.27.7",
    "typescript": "^5.7.0",
    "ws": "^8.18.0"
  }
}
