{
  "manifest_version": 3,
  "name": "Ares Browser Bridge",
  "version": "1.0.0",
  "minimum_chrome_version": "125",
  "description": "Owner-approved, authenticated high-speed bridge between Ares and existing browser tabs.",
  "key": "",
  "permissions": [
    "activeTab",
    "debugger",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "optional_permissions": ["downloads"],
  "optional_host_permissions": ["http://*/*", "https://*/*", "file:///*"],
  "background": { "service_worker": "src/service-worker.js", "type": "module" },
  "action": {
    "default_title": "Ares Browser Bridge",
    "default_popup": "src/popup.html"
  }
}
