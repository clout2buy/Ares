    "@ares/mind": "workspace:*",
    "@ares/operator": "workspace:*",
    "@ares/protocol": "workspace:*",
    "@ares/tools": "workspace:*",
    "ink": "^7.0.4",
    "react": "^19.2.6",
    "zod": "^3.23.8"
  }
}
