    "@crix/core": "workspace:*",
    "@crix/effects": "workspace:*",
    "@crix/mind": "workspace:*",
    "@crix/operator": "workspace:*",
    "@crix/protocol": "workspace:*",
    "@crix/tools": "workspace:*",
    "ink": "^7.0.4",
    "react": "^19.2.6",
    "zod": "^3.23.8"
  }
}
