{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ares",
  "mainBinaryName": "Ares",
  "version": "0.10.4",
  "identifier": "dev.ares.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ],
    "resources": {
      "runtime/": "runtime/",
      "installer/register-cli.ps1": "register-cli.ps1",
      "installer/unregister-cli.ps1": "unregister-cli.ps1"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/clout2buy/Ares/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBODQ4MkRGRkQ3QjI0RDIKUldUU0pIdjkzNEtFeXFPeUxhM0xGSlV6bVZuM1dsdVpQSVZwNjJBZkdzRGpEZ1lZT1RyQ1lZMzMK"
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: asset: http://asset.localhost; media-src 'self' data: asset: http://asset.localhost; frame-src 'self' data: blob: asset: http://asset.localhost https: http:; connect-src ipc: http://ipc.localhost http://127.0.0.1:8765 ws://127.0.0.1:8765 https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.ares/**",
          "$APPDATA/Ares/**",
          "$HOME/Desktop/Ares Workspace/**"
        ]
      }
    },
    "windows": [
      {
        "title": "Ares",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ]
  }
}
